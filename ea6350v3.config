# Target: Linksys EA6350v3 (ipq40xx / arm_cortex-a7_neon-vfpv4)
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_linksys_ea6350v3=y

# LuCI web interface
CONFIG_PACKAGE_luci=y

# XModem (xmodem-next)
CONFIG_PACKAGE_luci-app-xmodem-next=y

# eSIM: patched lpac (MBIM backend) + LuCI manager + Telegram bot + mbim-proxy
CONFIG_PACKAGE_lpac=y
CONFIG_LPAC_WITH_MBIM=y
CONFIG_LPAC_WITH_AT=y
CONFIG_PACKAGE_luci-app-lpac-manager=y
CONFIG_PACKAGE_xmodem-esim-bot=y
CONFIG_PACKAGE_mbim-utils=y

# Essential cellular modem support
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
